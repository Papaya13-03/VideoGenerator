# Local dev env: run API + worker on the host, infra (Postgres/Redis/MinIO) in Docker.
# Ports match docker-compose's host-published ports.
MPT_APP_ENABLE_REDIS=true
MPT_APP_USE_ARQ=true
MPT_APP_REDIS_HOST=localhost
MPT_APP_REDIS_PORT=6380

MPT_DATABASE_URL=postgresql+psycopg2://vg:vgpass@localhost:5434/videogenerator

MPT_STORAGE_BACKEND=s3
MPT_STORAGE_S3_ENDPOINT_URL=http://localhost:9000
MPT_STORAGE_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
MPT_STORAGE_S3_BUCKET=videogenerator
MPT_STORAGE_S3_ACCESS_KEY=minioadmin
MPT_STORAGE_S3_SECRET_KEY=minioadmin

# Dev secrets (override in production).
MPT_JWT_SECRET=dev-jwt-secret
MPT_SECRET_KEY=dev-encryption-secret
